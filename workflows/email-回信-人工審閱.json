    {
      "parameters": {
        "content": "## Draft response\nResponse based on specific instructions for that category of email",
        "height": 273,
        "width": 523,
        "color": 7
      },
      "id": "a7858b87-cd02-4f09-ab3e-dc92f4e8c768",
