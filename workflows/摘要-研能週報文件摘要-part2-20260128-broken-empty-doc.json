    {
      "parameters": {
        "operation": "update",
        "documentURL": "={{ $json.id }}",
        "actionsUi": {
          "actionFields": [
            {
              "action": "insert",
              "text": "=={{(() => {\n  const teamsData = $('Basic LLM Chain').item.json.output.teams;\n\n  const section = (title, arr) => {\n    if (!Array.isArray(arr) || arr.length === 0) return '';\n    return `【${title}】\\n` + arr.map(v => `- ${v}`).join('\\n') + '\\n\\n';\n  };\n\n  const renderTeam = (index, teamName, teamData) => {\n    if (!teamData) return '';\n\n    // ✅ Google Docs Insert 真正會生效的「分頁」\n    // 一定要是獨立段落：\\n\\f\\n\n    const pageBreak = index === 0 ? '' : '\\n\\f\\n';\n\n    return (\n      pageBreak +\n      `====================\\n` +\n      `【Team：${teamName}】\\n` +\n      `====================\\n\\n` +\n      section('本週重點', teamData['本週重點']) +\n      section('已完成事項', teamData['已完成事項']) +\n      section('進行中事項', teamData['進行中事項']) +\n      section('問題 / 風險', teamData['問題 / 風險']) +\n      section('後續待辦', teamData['後續待辦'])\n    ).trim() + '\\n\\n';\n  };\n\n  const teamOrder = [\n    'FAE',\n    '生產品檢',\n    '機構',\n    'HW',\n    'FW',\n    'SW',\n    'P760',\n    '系統測試',\n    'AIGC'\n  ];\n\n  return teamOrder\n    .map((teamName, idx) => renderTeam(idx, teamName, teamsData[teamName]))\n    .filter(Boolean)\n    .join('')\n    .trim();\n})()}}\n"
            }
          ]
        }
      },
