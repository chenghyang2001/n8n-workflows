      "parameters": {
        "schemaType": "manual",
        "inputSchema": "={\n  \"type\": \"object\",\n  \"required\":[\"is_match\", \"page_break\", \"team_order\", \"teams\"],\n  \"properties\": {\n    \"is_match\": {\n      \"type\": \"boolean\",\n      \"description\": \"是否成功依照指定的 8 個 teams 產生完整會議總結\"\n    },\n    \"page_break\": {\n      \"type\": \"string\",\n      \"description\": \"Google Docs 分頁符號；預設使用 Form Feed \\\\f（建議不要改）\",\n      \"default\": \"\\f\",\n      \"examples\": [\"\\f\"]\n    },\n    \"team_order\": {\n      \"type\": \"array\",\n      \"description\": \"8 個 teams 的顯示順序；輸出時可用 index+1 作為編號\",\n      \"minItems\": 8,\n      \"maxItems\": 8,\n      \"uniqueItems\": true,\n      \"items\": {\n        \"type\": \"string\",\n        \"enum\": [\n          \"FAE\",\n          \"生產品檢\",\n          \"機構\",\n          \"HW\",\n          \"FW\",\n          \"SW\",          \n          \"系統測試\",\n          \"AIGC\"\n        ]\n      },\n      \"default\": [\n        \"FAE\",\n        \"生產品檢\",\n        \"機構\",\n        \"HW\",\n        \"FW\",\n        \"SW\",        \n        \"系統測試\",\n        \"AIGC\"\n      ]\n    },\n    \"teams\": {\n      \"type\": \"object\",\n      \"required\": [\n        \"FAE\",\n        \"生產品檢\",\n        \"機構\",\n        \"HW\",\n        \"FW\",\n        \"SW\",        \n        \"系統測試\",\n        \"AIGC\"\n      ],\n      \"properties\": {\n        \"FAE\": { \"$ref\": \"#/definitions/team_summary\" },\n        \"生產品檢\": { \"$ref\": \"#/definitions/team_summary\" },\n        \"機構\": { \"$ref\": \"#/definitions/team_summary\" },\n        \"HW\": { \"$ref\": \"#/definitions/team_summary\" },\n        \"FW\": { \"$ref\": \"#/definitions/team_summary\" },\n        \"SW\": { \"$ref\": \"#/definitions/team_summary\" },        \n        \"系統測試\": { \"$ref\": \"#/definitions/team_summary\" },\n        \"AIGC\": { \"$ref\": \"#/definitions/team_summary\" }\n      }\n    }\n  },\n  \"definitions\": {\n    \"team_summary\": {\n      \"type\": \"object\",\n      \"required\": [\n        \"has_update\",\n        \"weekly_focus\",\n        \"completed\",\n        \"in_progress\",\n        \"issues_risks\",\n        \"next_actions\"\n      ],\n      \"properties\": {\n        \"has_update\": {\n          \"type\": \"boolean\",\n          \"description\": \"該 team 本週是否有實質更新\"\n        },\n        \"weekly_focus\": {\n          \"type\": \"array\",\n          \"items\": { \"type\": \"string\" },\n          \"description\": \"本週重點事項（事實描述）\"\n        },\n        \"completed\": {\n          \"type\": \"array\",\n          \"items\": { \"type\": \"string\" },\n          \"description\": \"已完成事項\"\n        },\n        \"in_progress\": {\n          \"type\": \"array\",\n          \"items\": { \"type\": \"string\" },\n          \"description\": \"進行中事項\"\n        },\n        \"issues_risks\": {\n          \"type\": \"array\",\n          \"items\": { \"type\": \"string\" },\n          \"description\": \"問題或風險；若無請留空陣列\"\n        },\n        \"next_actions\": {\n          \"type\": \"array\",\n          \"items\": { \"type\": \"string\" },\n          \"description\": \"後續待辦事項\"\n        }\n      }\n    }\n  }\n}\n"
      },
