    {
      "parameters": {
        "jsCode": "// This node gathers all video items and filters them by publication date.\nconst allVideos = $input.all().map(item => item.json);\n\n// Calculate the date and time from 24 hours ago.\nconst twentyFourHoursAgo = new Date(Date.now() - 24 * 60 * 60 * 1000);\n\n// Filter the videos to keep only those published after that time.\nconst recentVideos = allVideos.filter(video => {\n  // Check if the video has a 'publishedAt' date to avoid errors.\n  if (!video.snippet || !video.snippet.publishedAt) {\n    return false;\n  }\n  \n  const publishedDate = new Date(video.snippet.publishedAt);\n  return publishedDate > twentyFourHoursAgo;\n});\n\n// Return a single item containing only the recent videos.\nreturn [{\n  json: {\n    videos: recentVideos,\n    videoCount: recentVideos.length\n  }\n}];"
      },
