      "parameters": {
        "jsCode": "// This node takes the final list of raw subscriptions from the loop.\nconst allRawSubscriptions = $input.item.json.allSubscriptions;\n\n// We will create a new array to hold the cleaned data.\nconst cleanedSubscriptions = allRawSubscriptions.map(sub => {\n  // Check if the item is a valid raw subscription object from the API.\n  if (sub.snippet?.resourceId?.channelId) {\n    const channelId = sub.snippet.resourceId.channelId;\n\n    // YouTube's convention: an uploads playlist ID is the channel ID with 'UC' replaced by 'UU'.\n    const uploadsPlaylistId = 'UU' + channelId.substring(2);\n\n    return {\n      channelId: channelId,\n      channelTitle: sub.snippet.title || 'No Title',\n      uploadsPlaylistId: uploadsPlaylistId\n    };\n  }\n\n  // Return null for any invalid items so they can be filtered out.\n  return null;\n}).filter(Boolean); // This removes any null items from the list.\n\n// Pass the final, cleaned list to the next node.\nreturn cleanedSubscriptions;"
      },
