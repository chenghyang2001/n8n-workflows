      "parameters": {
        "jsCode": "// Get the list of videos from the input.\nconst allVideos = $input.item.json.videos;\n\n// If there are no videos, stop and don't send an email.\nif (!allVideos || allVideos.length === 0) {\n  return null;\n}\n\n// --- Start building the HTML table ---\nlet html = `\n<style>\n  body { font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif; margin: 0; padding: 20px; color: #333; }\n  .container { border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden; }\n  table { width: 100%; border-collapse: collapse; }\n  th, td { padding: 12px 15px; text-align: left; border-bottom: 1px solid #e0e0e0; }\n  th { background-color: #f7f7f7; font-size: 12px; text-transform: uppercase; }\n  tr:last-child td { border-bottom: none; }\n  a { color: #1a73e8; text-decoration: none; }\n  a:hover { text-decoration: underline; }\n</style>\n<div class=\"container\">\n  <table>\n    <thead>\n      <tr>\n        <th>Channel</th>\n        <th>Video Title</th>\n      </tr>\n    </thead>\n    <tbody>\n`;\n\n// --- Loop through each video and add it to the table ---\nfor (const video of allVideos) {\n  const channelName = video.snippet.channelTitle;\n  const videoTitle = video.snippet.title;\n  const videoId = video.snippet.resourceId.videoId;\n  const videoLink = `https://www.youtube.com/watch?v=${videoId}`;\n\n  html += `\n    <tr>\n      <td>${channelName}</td>\n      <td><a href=\"${videoLink}\" target=\"_blank\">${videoTitle}</a></td>\n    </tr>\n  `;\n}\n\n// --- Add the closing HTML tags *after* the loop is finished ---\nhtml += `\n    </tbody>\n  </table>\n</div>\n`;\n\n// --- Return the final HTML for the email node ---\nreturn { json: { html: html } };"
      },
      "id": "ffd07a38-e468-4364-b522-a84f7ee764f1",
      "name": "Build HTML Email",
      "type": "n8n-nodes-base.code",
