      "parameters": {
        "functionCode": "// 過濾並處理要刪除的郵件\nconst emailsToDelete = [];\n\nfor (const item of items) {\n  if (!item.json.id) {\n    continue;\n  }\n\n  // 取得郵件日期\n  const payload = item.json.payload;\n  if (payload && payload.headers) {\n    const dateHeader = payload.headers.find(h => h.name.toLowerCase() === 'date');\n    \n    if (dateHeader?.value) {\n      const emailDate = new Date(dateHeader.value);\n      const cutoffDate = new Date('2025-01-01');\n      \n      // 只處理 2024/01/01 之前的郵件\n      if (emailDate < cutoffDate) {\n        emailsToDelete.push({\n          json: {\n            messageId: item.json.id,\n            date: dateHeader.value,\n            subject: payload.headers.find(h => h.name.toLowerCase() === 'subject')?.value || 'No Subject'\n          }\n        });\n      }\n    }\n  }\n}\n\nreturn emailsToDelete;"
      },
