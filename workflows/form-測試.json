      "parameters": {
        "jsCode": "// Code Node: 格式化 task_done_today 為編號列表並附加 Note 和 URL\n\n// 獲取輸入資料 - 從 config-1 節點\nconst inputData = $input.first().json;\nconst taskDoneToday = inputData.content; // config-1 中已將 task_done_today 設為 content\nconst note = inputData.note || '';\nconst url1 = inputData.url1 || ''; // 從輸入資料獲取 url1\nconst createDate = inputData.create_date;\n\n// 將 task_done_today 轉換為編號列表\nlet formattedContent = '';\n\nif (Array.isArray(taskDoneToday)) {\n  // 如果是陣列，創建編號列表\n  taskDoneToday.forEach((task, index) => {\n    formattedContent += `${index + 1}. ${task}\\n`;\n  });\n} else if (taskDoneToday) {\n  // 如果是單一項目或字串\n  if (typeof taskDoneToday === 'string') {\n    // 嘗試解析陣列字串\n    try {\n      const parsed = JSON.parse(taskDoneToday);\n      if (Array.isArray(parsed)) {\n        parsed.forEach((task, index) => {\n          formattedContent += `${index + 1}. ${task}\\n`;\n        });\n      } else {\n        formattedContent = `1. ${taskDoneToday}\\n`;\n      }\n    } catch (e) {\n      formattedContent = `1. ${taskDoneToday}\\n`;\n    }\n  } else {\n    formattedContent = `1. ${taskDoneToday}\\n`;\n  }\n}\n\n// 在末尾附加 Note 內容（如果有的話）\nif (note && note.trim() !== '') {\n  formattedContent += `\\n備註：${note}`;\n}\n\n// 在末尾附加 URL 內容（如果有的話）\nif (url1 && url1.trim() !== '') {\n  formattedContent += `\\n連結：${url1}`;\n}\n\n// 回傳格式化後的資料\nreturn [\n  {\n    json: {\n      create_date: createDate,\n      content: formattedContent.trim(),\n      original_tasks: taskDoneToday,\n      note: note,\n      url_1: url1\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
