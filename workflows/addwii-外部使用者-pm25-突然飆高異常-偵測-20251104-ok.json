    {
      "parameters": {
        "jsCode": "// 取得輸入資料\nconst inputData = $input.all();\n\n// 初始化結果陣列\nconst output = [];\n\n// 處理每個輸入項目\nfor (const item of inputData) {\n  const json = item.json;\n  \n  // 計算 room_id 陣列的大小\n  let roomIdCount = 0;\n  \n  if (json.room_id && Array.isArray(json.room_id)) {\n    roomIdCount = json.room_id.length;\n  }\n  \n  // 計算 client_name 陣列的大小（額外提供）\n  let clientNameCount = 0;\n  \n  if (json.client_name && Array.isArray(json.client_name)) {\n    clientNameCount = json.client_name.length;\n  }\n  \n  // 輸出結果\n  output.push({\n    json: {\n      room_id_count: roomIdCount,\n      client_name_count: clientNameCount,\n      original_data: json\n    }\n  });\n}\n\nreturn output;"
      },
