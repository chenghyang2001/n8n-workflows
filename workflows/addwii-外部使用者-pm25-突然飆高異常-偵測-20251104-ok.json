    {
      "parameters": {
        "jsCode": "// n8n Code Node - PM2.5 Statistics Calculator (Integer Output)\n// This code calculates min, max, average, and median from the PM2.5 array as integers\n\nconst items = $input.all();\nlet pm25Values = [];\n\n// Extract PM2.5 values from each item\nfor (const item of items) {\n  // Check for different possible property names\n  if (item.json.PM25) {\n    if (Array.isArray(item.json.PM25)) {\n      pm25Values = pm25Values.concat(item.json.PM25);\n    } else {\n      pm25Values.push(item.json.PM25);\n    }\n  }\n  if (item.json.pm25) {\n    if (Array.isArray(item.json.pm25)) {\n      pm25Values = pm25Values.concat(item.json.pm25);\n    } else {\n      pm25Values.push(item.json.pm25);\n    }\n  }\n  if (item.json.PM2_5) {\n    if (Array.isArray(item.json.PM2_5)) {\n      pm25Values = pm25Values.concat(item.json.PM2_5);\n    } else {\n      pm25Values.push(item.json.PM2_5);\n    }\n  }\n  if (item.json.pm2_5) {\n    if (Array.isArray(item.json.pm2_5)) {\n      pm25Values = pm25Values.concat(item.json.pm2_5);\n    } else {\n      pm25Values.push(item.json.pm2_5);\n    }\n  }\n}\n\n// Convert all values to numbers and filter out invalid entries\npm25Values = pm25Values\n  .map(val => parseFloat(val))\n  .filter(val => !isNaN(val));\n\n// Function to calculate integer-based statistics\nfunction calculateStatistics(values) {\n  if (values.length === 0) {\n    return { \n      error: \"No valid PM2.5 values found\", \n      count: 0 \n    };\n  }\n\n  const sortedValues = [...values].sort((a, b) => a - b);\n\n  const min = Math.round(Math.min(...values));\n  const max = Math.round(Math.max(...values));\n  const sum = values.reduce((acc, val) => acc + val, 0);\n  const average = Math.round(sum / values.length);\n\n  let median;\n  const middleIndex = Math.floor(sortedValues.length / 2);\n\n  if (sortedValues.length % 2 === 0) {\n    median = Math.round((sortedValues[middleIndex - 1] + sortedValues[middleIndex]) / 2);\n  } else {\n    median = Math.round(sortedValues[middleIndex]);\n  }\n\n  // Calculate additional PM2.5 specific metrics\n  const nonZeroValues = values.filter(v => v > 0);\n  const nonZeroCount = nonZeroValues.length;\n  const nonZeroPercentage = Math.round((nonZeroCount / values.length) * 100);\n  \n  // AQI categories for PM2.5 (μg/m³) - ensure integer counts\n  const goodCount = values.filter(v => v >= 0 && v <= 12).length;\n  const moderateCount = values.filter(v => v > 12 && v <= 35).length;\n  const unhealthySensitiveCount = values.filter(v => v > 35 && v <= 55).length;\n  const unhealthyCount = values.filter(v => v > 55 && v <= 150).length;\n  const veryUnhealthyCount = values.filter(v => v > 150 && v <= 250).length;\n  const hazardousCount = values.filter(v => v > 250).length;\n\n  return {\n    min: Number(min),\n    max: Number(max),\n    average: Number(average),\n    median: Number(median),\n    count: Number(values.length),\n    nonZeroCount: Number(nonZeroCount),\n    nonZeroPercentage: Number(nonZeroPercentage),\n    goodCount: Number(goodCount),\n    moderateCount: Number(moderateCount),\n    unhealthySensitiveCount: Number(unhealthySensitiveCount),\n    unhealthyCount: Number(unhealthyCount),\n    veryUnhealthyCount: Number(veryUnhealthyCount),\n    hazardousCount: Number(hazardousCount),\n    allValues: values.map(v => Math.round(v))\n  };\n}\n\nconst statistics = calculateStatistics(pm25Values);\n\n// Create clean output with camelCase naming to avoid n8n parsing issues\nreturn [{\n  json: {\n    pm25Statistics: {\n      minimum: Number(statistics.min || 0),\n      maximum: Number(statistics.max || 0),\n      average: Number(statistics.average || 0),\n      median: Number(statistics.median || 0),\n      totalCount: Number(statistics.count || 0),\n      nonZeroCount: Number(statistics.nonZeroCount || 0),\n      nonZeroPercentage: Number(statistics.nonZeroPercentage || 0)\n    },\n    aqiDistribution: {\n      good: Number(statistics.goodCount || 0),\n      moderate: Number(statistics.moderateCount || 0),\n      unhealthySensitive: Number(statistics.unhealthySensitiveCount || 0),\n      unhealthy: Number(statistics.unhealthyCount || 0),\n      veryUnhealthy: Number(statistics.veryUnhealthyCount || 0),\n      hazardous: Number(statistics.hazardousCount || 0)\n    },\n    rawPm25Values: statistics.allValues || [],\n    calculatedAt: new Date().toISOString()\n  }\n}];"
      },
