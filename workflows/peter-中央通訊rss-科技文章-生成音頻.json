  "nodes": [
    {
      "parameters": {
        "jsCode": "// 取得前五篇 RSS 文章\nconst articles = $input.all().slice(0, 15);\n\n// 提取標題並清理格式\nfunction cleanTitle(title) {\n  return title\n    .replace(/[\\r\\n\\t]/g, ' ')           // 移除換行和制表符\n    .replace(/\\s+/g, ' ')               // 合併多個空格\n    .replace(/[\"\"「」『』]/g, '\"')        // 統一引號\n    .trim();                            // 移除前後空格\n}\n\n// 建立標題列表\nconst titlesList = articles.map((item, index) => {\n  const cleanedTitle = cleanTitle(item.json.title || '無標題');\n  const pubDate = item.json.pubDate || '';\n  const link = item.json.link || '';\n  \n  return {\n    序號: index + 1,\n    標題: cleanedTitle,\n    發布時間: pubDate,\n    連結: link\n  };\n});\n\n// 建立純標題文字列表\nconst titlesOnly = titlesList.map(item => `${item.序號}. ${item.標題}`).join('\\n');\n\nreturn [\n  {\n    json: {\n      文章標題列表: titlesList,\n      純標題文字: titlesOnly,\n      總文章數: articles.length,\n      擷取時間: new Date().toLocaleString('zh-TW', {\n        timeZone: 'Asia/Taipei',\n        year: 'numeric',\n        month: '2-digit',\n        day: '2-digit',\n        hour: '2-digit',\n        minute: '2-digit',\n        second: '2-digit'\n      })\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1000,
        480
      ],
      "id": "fd46d544-9705-4782-a3d2-7e1cf0286192",
      "name": "提取標題"
    },
    {
