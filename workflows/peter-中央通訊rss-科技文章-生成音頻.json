    {
      "parameters": {
        "jsCode": "// 格式化輸出結果\nconst data = $input.first().json;\n\nconsole.log('=== RSS 文章標題擷取結果 ===');\nconsole.log(`擷取時間: ${data.擷取時間}`);\nconsole.log(`總文章數: ${data.總文章數}`);\nconsole.log('\\n=== 文章標題列表 ===');\nconsole.log(data.純標題文字);\n\n// 顯示詳細資訊\nconsole.log('\\n=== 詳細資訊 ===');\ndata.文章標題列表.forEach(article => {\n  console.log(`${article.序號}. ${article.標題}`);\n  console.log(`   發布時間: ${article.發布時間}`);\n  console.log(`   連結: ${article.連結}`);\n  console.log('---');\n});\n\nreturn $input.all();\n"
      },
