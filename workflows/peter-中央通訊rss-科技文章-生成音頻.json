        "jsCode": "console.log('⚠️ 沒有找到任何文章');\nconsole.log('請檢查 RSS 網址是否正確或網路連線狀態');\n\nreturn [{\n  json: {\n    錯誤訊息: '沒有找到任何文章',\n    建議: '請檢查 RSS 網址是否正確或網路連線狀態',\n    時間: new Date().toLocaleString('zh-TW', {\n      timeZone: 'Asia/Taipei'\n    })\n  }\n}];\n"
