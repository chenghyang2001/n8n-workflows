            {
              "id": "8d7c6b5a-4e3f-2g1h-9i0j-k1l2m3n4o5p6",
              "leftValue": "={{ $json.總文章數 }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
