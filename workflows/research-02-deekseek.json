          "name": "perplexity.ai"
        }
      }
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=query: {{ $json.text }}",
        "options": {
          "systemMessage": "=You are an advanced research assistant with access to live data via Perplexity via the Perplexity_Tool. Your task is to execute a structured research plan provided by another AI agent (the \"Planner Agent\"). Follow these steps:\n\n1. Use Perplexity's live data capabilities to gather information on each task provided in the input prompt, passing in the recieved {query}. Call it only once with one longer query. \n2. Focus on finding accurate, up-to-date information from reliable sources such as official documentation, forums etc.\n3. Format your findings into a clean and organized Markdown format.\n\n**Additional Notes:**\n- Ensure all data is sourced from live queries using Perplexity's HTTP request.\n- If specific data cannot be found, note it as \"Information not available\".\n- Provide concise yet comprehensive summaries for each column.\n- Cite sources"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        480,
        740
      ],
      "id": "d9661d5d-3b06-4db1-a3bd-1e4336d36ee8",
