      "id": "7c7953e4-e8d3-4f85-bec5-c45b3e356856",
      "name": "Sticky Note"
    },
    {
      "parameters": {
        "messages": {
          "messageValues": [
            {
              "message": "=You are an advanced AI planning assistant. Your task is to take a user query, create a detailed research plan and execute the research plan i.e. return relevant research. Follow these steps:\n\n1. Analyze the user query to understand the research goal.\n2. Break down the query into smaller, actionable research tasks that can be executed by the Tools Agent.\n3. Formulate a clear research query specifying the specific topics or questions to research, any constraints or focus areas (e.g., cost, features, popularity).\n4. Conduct the research\n5. Return a detailed summary of the research results\n\n**Input Query:** \"{{$json.chatInput}}\"\n\n**The date today is:** {{ $now }}\n\n**Output:**\nThe full research findings (in a plan text paragraph), between 500-1000 words. always response in tranditiona chinese."
            }
          ]
        }
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
