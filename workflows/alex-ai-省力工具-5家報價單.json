    {
      "parameters": {
        "jsCode": "// 這個節點要接在 Convert to PDF 後面；binary property 名稱是 \"data\"\nconst item = $input.item;\n\n// 從 JSON 取單號、客戶公司\nconst quoteNo  = $('Loop Over Items').first().json.quoteNo || 'NOQUOTE';\nconst customer = ($('Loop Over Items').first().json.customer.company ) || 'CUSTOMER';\n\n// 去除檔名禁用字元（/ \\ : * ? \" < > |）與多餘空白\nconst sanitize = s =>\n  String(s).replace(/[\\/\\\\:*?\"<>|]/g, '').replace(/\\s+/g, ' ').trim();\n\n// 依「位元組」長度做截斷（避免中英混合超過系統限制）\nfunction truncateByBytes(str, maxBytes) {\n  let out = '', bytes = 0;\n  for (const ch of str) {\n    const b = Buffer.from(ch, 'utf8').length;\n    if (bytes + b > maxBytes) break;\n    bytes += b;\n    out += ch;\n  }\n  return out;\n}\n\n// 組檔名（保留 .pdf 4 bytes，這裡預留 4；總長度上限可自行微調）\nconst base = `報價單-${sanitize(quoteNo)}-${sanitize(customer)}`;\nconst limited = truncateByBytes(base, 120 - 4);   // 120 bytes 內（含中文安全）\nconst finalName = `${limited}.pdf`;\n\n// 寫回 binary 檔名\nif (item.binary?.data) {\n  item.binary.data.fileName = finalName;\n} else {\n  throw new Error('找不到 binary property: data');\n}\n\nreturn item;\n"
      },
