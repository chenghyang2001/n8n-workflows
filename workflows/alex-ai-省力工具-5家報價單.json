      "parameters": {
        "html": "<!DOCTYPE html>\n<html lang=\"zh-TW\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>報價單 {{$json.quoteNo}}</title>\n</head>\n<body style=\"font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;margin:0;padding:0.5rem;\">\n  <div style=\"max-width:700px;margin:auto;padding:1.5rem;background:#fff;box-shadow:0 4px 6px rgba(0,0,0,.1),0 1px 3px rgba(0,0,0,.08);\">\n    <!-- Header -->\n    <div style=\"text-align:center;margin-bottom:1.5rem;\">\n      <h1 style=\"font-size:2rem;font-weight:bold;color:#2d3748;\">報價單</h1>\n      <div style=\"display:flex;justify-content:space-around;font-size:.75rem;color:#718096;line-height:1.5;margin-top:.5rem;\">\n        <p>報價單號：<span style=\"color:#4a5568;font-weight:600;\">{{$json.quoteNo}}</span></p>\n        <p>報價日期：<span style=\"color:#4a5568;font-weight:600;\">{{$json.date}}</span></p>\n        <p>有效期限：<span style=\"color:#4a5568;font-weight:600;\">{{$json.dueDays}} 天</span></p>\n      </div>\n    </div>\n\n    <!-- Parties -->\n    <div style=\"display:flex;justify-content:space-between;margin-bottom:1.5rem;padding:1rem;background:#f7fafc;border-radius:.5rem;\">\n      <div style=\"flex:1;margin-right:1rem;\">\n        <h2 style=\"font-size:1rem;font-weight:bold;color:#4a5568;margin-bottom:.5rem;\">報價廠商</h2>\n        <p style=\"font-size:.8rem;color:#4a5568;line-height:1.5;\">公司名稱：{{$json.issuer.company}}</p>\n        <p style=\"font-size:.8rem;color:#4a5568;line-height:1.5;\">統一編號：{{$json.issuer.taxId}}</p>\n        <p style=\"font-size:.8rem;color:#4a5568;line-height:1.5;\">地址：{{$json.issuer.address}}</p>\n        <p style=\"font-size:.8rem;color:#4a5568;line-height:1.5;\">聯絡人：{{$json.issuer.contact}}{{$json.issuer.phone ? '｜' + $json.issuer.phone : ''}}</p>\n        <p style=\"font-size:.8rem;color:#4a5568;line-height:1.5;\">Email：{{$json.issuer.email}}</p>\n      </div>\n      <div style=\"flex:1;margin-left:1rem;\">\n        <h2 style=\"font-size:1rem;font-weight:bold;color:#4a5568;margin-bottom:.5rem;\">客戶</h2>\n        <p style=\"font-size:.8rem;color:#4a5568;line-height:1.5;\">客戶名稱：{{$json.customer.company}}</p>\n        <p style=\"font-size:.8rem;color:#4a5568;line-height:1.5;\">聯絡人：{{$json.customer.contact}}</p>\n        <p style=\"font-size:.8rem;color:#4a5568;line-height:1.5;\">電話：{{$json.customer.phone}}</p>\n        <p style=\"font-size:.8rem;color:#4a5568;line-height:1.5;\">Email：{{$json.customer.email}}</p>\n      </div>\n    </div>\n\n    <!-- Items -->\n    <div style=\"overflow-x:auto;\">\n      <table style=\"width:100%;text-align:left;border-collapse:collapse;\">\n        <thead>\n          <tr style=\"background:#e2e8f0;\">\n            <th style=\"padding:.75rem;white-space:nowrap;border-top-left-radius:.5rem;font-size:.8rem;\">品名/服務項目</th>\n            <th style=\"padding:.75rem;white-space:nowrap;font-size:.8rem;\">規格</th>\n            <th style=\"padding:.75rem;white-space:nowrap;text-align:right;font-size:.8rem;\">數量</th>\n            <th style=\"padding:.75rem;white-space:nowrap;text-align:right;font-size:.8rem;\">單價</th>\n            <th style=\"padding:.75rem;white-space:nowrap;text-align:right;border-top-right-radius:.5rem;font-size:.8rem;\">小計</th>\n          </tr>\n        </thead>\n        <tbody>\n          {{\n            $json.items\n              .map(i => {\n                const money = (n) => 'NT$' + Number(n).toLocaleString('en-US', { minimumFractionDigits: 2 });\n                return `\n                <tr>\n                  <td style=\"padding:.75rem;border-bottom:1px solid #e2e8f0;white-space:nowrap;font-size:.8rem;\">${i.name || ''}</td>\n                  <td style=\"padding:.75rem;border-bottom:1px solid #e2e8f0;white-space:nowrap;font-size:.8rem;\">${i.spec || ''}</td>\n                  <td style=\"padding:.75rem;border-bottom:1px solid #e2e8f0;white-space:nowrap;text-align:right;font-size:.8rem;\">${i.qty}</td>\n                  <td style=\"padding:.75rem;border-bottom:1px solid #e2e8f0;white-space:nowrap;text-align:right;font-size:.8rem;\">${money(i.unitPrice)}</td>\n                  <td style=\"padding:.75rem;border-bottom:1px solid #e2e8f0;white-space:nowrap;text-align:right;font-size:.8rem;\">${money(i.lineTotal)}</td>\n                </tr>`;\n              })\n              .join('')\n          }}\n        </tbody>\n      </table>\n    </div>\n\n    <!-- Totals -->\n    <div style=\"display:flex;justify-content:flex-end;margin-top:1.5rem;\">\n      <div style=\"width:100%;max-width:15rem;\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;padding:.25rem 0;\">\n          <span style=\"font-size:.75rem;color:#4a5568;font-weight:600;\">總金額（未稅）：</span>\n          <span style=\"font-size:.75rem;color:#4a5568;font-weight:600;\">\n            {{ (n => 'NT$' + Number(n).toLocaleString('en-US',{minimumFractionDigits:2}))($json.subtotal) }}\n          </span>\n        </div>\n        <div style=\"display:flex;justify-content:space-between;align-items:center;padding:.25rem 0;\">\n          <span style=\"font-size:.75rem;color:#4a5568;font-weight:600;\">營業稅（{{Math.round($json.taxRate*100)}}%）：</span>\n          <span style=\"font-size:.75rem;color:#4a5568;font-weight:600;\">\n            {{ (n => 'NT$' + Number(n).toLocaleString('en-US',{minimumFractionDigits:2}))($json.tax) }}\n          </span>\n        </div>\n        <div style=\"display:flex;justify-content:space-between;align-items:center;padding-top:.75rem;border-top:2px solid #cbd5e0;\">\n          <span style=\"font-size:1rem;font-weight:bold;color:#2d3748;\">總計（含稅）：</span>\n          <span style=\"font-size:1.125rem;font-weight:bold;color:#3182ce;\">\n            {{ (n => 'NT$' + Number(n).toLocaleString('en-US',{minimumFractionDigits:2}))($json.total) }}\n          </span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Notes -->\n    <div style=\"margin-top:1.5rem;padding:1rem;background:#f7fafc;border-radius:.5rem;\">\n      <h3 style=\"font-size:1rem;font-weight:bold;color:#4a5568;margin-bottom:.5rem;\">備註</h3>\n      <ul style=\"list-style-type:disc;padding-left:1.25rem;font-size:.8rem;color:#4a5568;\">\n        <li style=\"line-height:1.5;\">付款條件：簽約時 50%，驗收完成 50%。</li>\n        <li style=\"line-height:1.5;\">交期：簽約後 30 個工作天內完成。</li>\n        <li style=\"line-height:1.5;\">此報價有效期限為 {{$json.dueDays}} 天。</li>\n      </ul>\n      {{ $json.errors && $json.errors.length\n          ? `<div style=\"margin-top:.5rem;color:#b91c1c;font-size:.8rem;\"><strong>注意：</strong>${$json.errors.join('；')}</div>`\n          : '' }}\n    </div>\n  </div>\n</body>\n</html>\n"
      },
