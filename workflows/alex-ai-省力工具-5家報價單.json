    {
      "parameters": {
        "jsCode": "// 單一輸入：合併後的列（公司/客戶/品項混在同一陣列）\nconst rows = $input.all().map(i => i.json);\n\n// 分類\nconst issuerRow   = rows.find(r => String(r['類型']).trim() === '服務廠商') || {};\nconst customerRows= rows.filter(r => String(r['類型']).trim() === '客戶');\nconst itemRowsAll = rows.filter(r => r['單號'] !== undefined);\n\n// 組 issuer（你的抬頭）\nconst issuer = {\n  company: issuerRow['公司名稱'] || '',\n  taxId:   issuerRow['統一編號'] || '',\n  address: issuerRow['地址'] || '',\n  contact: issuerRow['聯絡人'] || '',\n  phone:   issuerRow['電話'] || '',\n  email:   issuerRow['電子郵件'] || '',\n  taxRate: 0.05,  // 若要公司化可在 issuerRow 加欄 '稅率'\n  dueDays: 15,    // 同上，可加 '有效期限(天)'\n};\n\n// 客戶對照（key = 公司名稱）\nconst customerMap = new Map(customerRows.map(r => [\n  r['公司名稱'],\n  {\n    company: r['公司名稱'],\n    contact: r['聯絡人'] || '',\n    phone:   r['電話']   || '',\n    email:   r['電子郵件'] || '',\n    address: r['地址'] || '',\n  }\n]));\n\n// 僅處理未寄送/未勾選\nconst itemRows = itemRowsAll.filter(r => {\n  const s = String(r['狀態']).trim().toLowerCase();\n  return !(s === 'true' || s === '1' || s === '是' || s === '已寄送' || s === '已勾選');\n});\n\n// 以「單號」分組（同單號＝同一張）\nconst byQuote = new Map();\nfor (const r of itemRows) {\n  const q = r['單號'] || 'NO_QUOTE';\n  if (!byQuote.has(q)) byQuote.set(q, []);\n  byQuote.get(q).push(r);\n}\n\n// 輸出每張報價單 1 item\nconst out = [];\nfor (const [quoteNo, rowsOfQuote] of byQuote.entries()) {\n  const errors = [];\n\n  // 檢查同單號內廠商一致\n  const vendors = [...new Set(rowsOfQuote.map(x => (x['廠商'] || '').trim()))].filter(Boolean);\n  if (vendors.length === 0) errors.push(`單號 ${quoteNo} 缺少「廠商」欄位`);\n  if (vendors.length > 1)  errors.push(`單號 ${quoteNo} 含多個廠商：${vendors.join(', ')}`);\n\n  const vendor = vendors[0] || '';\n  const customer = customerMap.get(vendor);\n  if (!customer)           errors.push(`單號 ${quoteNo} 的廠商「${vendor}」在客戶清單找不到相同公司名稱`);\n  else if (!customer.email)errors.push(`單號 ${quoteNo} 的客戶「${vendor}」缺少電子郵件`);\n\n  // 依 row_number 排序（若有）\n  rowsOfQuote.sort((a,b) => (Number(a.row_number||0) - Number(b.row_number||0)));\n\n  // 明細\n  const items = rowsOfQuote.map(x => {\n    const qty = Number(String(x['數量'] ?? 1).replace(/[^0-9.\\-]/g,'')) || 1;\n    const unitPrice = Number(String(x['單價'] ?? 0).replace(/[^0-9.\\-]/g,'')) || 0;\n    return {\n      name: x['品名/服務項目'],\n      spec: x['規格'],\n      qty,\n      unitPrice,\n      lineTotal: Number((qty * unitPrice).toFixed(2)),\n    };\n  });\n\n  // 金額\n  const subtotal = Number(items.reduce((s, it) => s + it.lineTotal, 0).toFixed(2));\n  const tax      = Number((subtotal * issuer.taxRate).toFixed(2));\n  const total    = Number((subtotal + tax).toFixed(2));\n\n  out.push({\n    json: {\n      valid: errors.length === 0,\n      errors,\n      quoteNo,\n      date: new Date().toISOString().slice(0,10),\n      issuer,\n      customer: customer || { company: vendor },\n      items,\n      subtotal,\n      taxRate: issuer.taxRate,\n      tax,\n      total,\n      dueDays: issuer.dueDays,\n      _rowsToUpdate: rowsOfQuote.map(x => x.row_number).filter(n => n !== undefined), // 供回寫\n    }\n  });\n}\n\nreturn out;\n"
      },
